{
  "manifest_version": 3,
  "name": "Connectol V2",
  "version": "2.0",
  "description": "Connectol Project Bridge",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
